    "sql_text": "-- [financial_metrics]\nWITH base AS (\n  SELECT\n    period_year,\n    period_month,\n    metric_name,\n    metric_value,\n    metric_unit,\n    evaluation_level\n  FROM vw_financial_metrics\n  WHERE taxpayer_id = '91310115MA2KZZZZZZ'\n    AND ((period_year = 2024 AND period_month = 3 AND period_type IN ('quarterly', 'annual'))\n         OR (period_year = 2025 AND period_month = 3 AND period_type IN ('quarterly', 'annual')))\n    AND metric_name IN ('净利率', '增值税税负率', '企业所得税税负率')\n)\nSELECT\n  metric_name,\n  MAX(CASE WHEN period_year = 2024 AND period_month = 3 THEN metric_value END) AS \"2024年3月\",\n  MAX(CASE WHEN period_year = 2025 AND period_month = 3 THEN metric_value END) AS \"2025年3月\",\n  ROUND(\n    MAX(CASE WHEN period_year = 2025 AND period_month = 3 THEN metric_value END) -\n    MAX(CASE WHEN period_year = 2024 AND period_month = 3 THEN metric_value END),\n    2\n  ) AS \"变动\",\n  MAX(metric_unit) AS metric_unit\nFROM base\nGROUP BY metric_name\nLIMIT 1000\n\n-- [vat]\nWITH latest AS (\n  SELECT taxpayer_id, taxpayer_name, period_year, period_month,\n         item_type, time_range, taxpayer_type, revision_no,\n         sales_taxable_rate, sales_goods, sales_services, sales_adjustment_check, sales_simple_method, sales_simple_adjust_check, sales_export_credit_refund, sales_tax_free, sales_tax_free_goods, sales_tax_free_services, output_tax, input_tax, last_period_credit, transfer_out, export_refund, tax_check_supplement, deductible_total, actual_deduct, tax_payable, end_credit, simple_tax, simple_tax_check_supplement, tax_reduction, total_tax_payable, unpaid_begin, export_receipt_tax, paid_current, prepaid_installment, prepaid_export_receipt, paid_last_period, paid_arrears, unpaid_end, arrears, supplement_refund, immediate_refund, unpaid_check_begin, paid_check_current, unpaid_check_end, city_maintenance_tax, education_surcharge, local_education_surcharge,\n    ROW_NUMBER() OVER (\n      PARTITION BY taxpayer_id, period_year, period_month, item_type, time_range\n      ORDER BY revision_no DESC\n    ) AS rn\n  FROM vw_vat_return_general\n  WHERE taxpayer_id = '91310115MA2KZZZZZZ'\n    AND (period_year*100+period_month) BETWEEN 202403 AND 202503\n)\nSELECT taxpayer_id, taxpayer_name, period_year, period_month,\n       item_type, time_range, taxpayer_type, revision_no,\n       sales_taxable_rate, sales_goods, sales_services, sales_adjustment_check, sales_simple_method, sales_simple_adjust_check, sales_export_credit_refund, sales_tax_free, sales_tax_free_goods, sales_tax_free_services, output_tax, input_tax, last_period_credit, transfer_out, export_refund, tax_check_supplement, deductible_total, actual_deduct, tax_payable, end_credit, simple_tax, simple_tax_check_supplement, tax_reduction, total_tax_payable, unpaid_begin, export_receipt_tax, paid_current, prepaid_installment, prepaid_export_receipt, paid_last_period, paid_arrears, unpaid_end, arrears, supplement_refund, immediate_refund, unpaid_check_begin, paid_check_current, unpaid_check_end, city_maintenance_tax, education_surcharge, local_education_surcharge\nFROM latest\nWHERE rn = 1\nORDER BY period_year, period_month\nLIMIT 1000;\n\n-- [eit]\nWITH latest AS (\n  SELECT taxpayer_id, taxpayer_name, period_year, revision_no,\n         revenue, operating_profit, taxable_income, actual_tax_payable\n  FROM vw_eit_annual_main\n  WHERE taxpayer_id = '91310115MA2KZZZZZZ'\n    AND period_year BETWEEN 2024 AND 2025\n),\nfiltered AS (\n  SELECT taxpayer_id, taxpayer_name, period_year,\n         revenue,\n         operating_profit,\n         taxable_income,\n         actual_tax_payable,\n         CASE WHEN revenue > 0 THEN ROUND(operating_profit * 100.0 / revenue, 2) ELSE NULL END AS operating_profit_margin,\n         CASE WHEN revenue > 0 THEN ROUND(actual_tax_payable * 100.0 / revenue, 2) ELSE NULL END AS eit_tax_burden_rate\n  FROM latest\n  WHERE revision_no = (SELECT MAX(revision_no) FROM latest AS sub WHERE sub.taxpayer_id = latest.taxpayer_id AND sub.period_year = latest.period_year)\n)\nSELECT taxpayer_id, taxpayer_name, period_year,\n       revenue, operating_profit, taxable_income, actual_tax_payable,\n       operating_profit_margin, eit_tax_burden_rate,\n       0 AS sort_key\nFROM filtered\nUNION ALL\nSELECT taxpayer_id, taxpayer_name, '合计' AS period_year,\n       SUM(revenue) AS revenue,\n       SUM(operating_profit) AS operating_profit,\n       SUM(taxable_income) AS taxable_income,\n       SUM(actual_tax_payable) AS actual_tax_payable,\n       CASE WHEN SUM(revenue) > 0 THEN ROUND(SUM(operating_profit) * 100.0 / SUM(revenue), 2) ELSE NULL END AS operating_profit_margin,\n       CASE WHEN SUM(revenue) > 0 THEN ROUND(SUM(actual_tax_payable) * 100.0 / SUM(revenue), 2) ELSE NULL END AS eit_tax_burden_rate,\n       1 AS sort_key\nFROM filtered\nGROUP BY taxpayer_id, taxpayer_name\nORDER BY sort_key, period_year\nLIMIT 1000;",
