  ],\n    \"limit\": 1000\n  },\n  \"need_clarification\": false,\n  \"clarifying_questions\": []\n}",
    "sql_text": "-- [financial_metrics]\nWITH t1 AS (\n  SELECT metric_name, metric_value, metric_unit\n  FROM vw_financial_metrics\n  WHERE taxpayer_id = '91310115MA2KZZZZZZ'\n    AND period_year = 2024 AND period_month = 3\n    AND period_type IN ('quarterly', 'annual')\n    AND metric_name IN ('净利率', '增值税税负率', '企业所得税税负率')\n),\nt2 AS (\n  SELECT metric_name, metric_value, metric_unit\n  FROM vw_financial_metrics\n  WHERE taxpayer_id = '91310115MA2KZZZZZZ'\n    AND period_year = 2025 AND period_month = 3\n    AND period_type IN ('quarterly', 'annual')\n    AND metric_name IN ('净利率', '增值税税负率', '企业所得税税负率')\n)\nSELECT t1.metric_name,\n       t1.metric_value AS \"2024年3月\",\n       t2.metric_value AS \"2025年3月\",\n       ROUND(t2.metric_value - t1.metric_value, 2) AS \"变动\",\n       t1.metric_unit\nFROM t1 JOIN t2 ON t1.metric_name = t2.metric_name\nLIMIT 1000\n\n-- [vat]\nWITH latest AS (\n  SELECT taxpayer_id, taxpayer_name, period_year, period_month,\n         item_type, time_range, taxpayer_type, revision_no,\n         sales_taxable_rate, sales_goods, sales_services, sales_adjustment_check, sales_simple_method, sales_simple_adjust_check, sales_export_credit_refund, sales_tax_free, sales_tax_free_goods, sales_tax_free_services, output_tax, input_tax, last_period_credit, transfer_out, export_refund, tax_check_supplement, deductible_total, actual_deduct, tax_payable, end_credit, simple_tax, simple_tax_check_supplement, tax_reduction, total_tax_payable, unpaid_begin, export_receipt_tax, paid_current, prepaid_installment, prepaid_export_receipt, paid_last_period, paid_arrears, unpaid_end, arrears, supplement_refund, immediate_refund, unpaid_check_begin, paid_check_current, unpaid_check_end, city_maintenance_tax, education_surcharge, local_education_surcharge,\n    ROW_NUMBER() OVER (\n      PARTITION BY taxpayer_id, period_year, period_month, item_type, time_range\n      ORDER BY revision_no DESC\n    ) AS rn\n  FROM vw_vat_return_general\n  WHERE taxpayer_id = '91310115MA2KZZZZZZ'\n    AND (period_year*100+period_month) BETWEEN 202403 AND 202503\n    AND item_type = '一般项目'\n    AND time_range = '累计'\n)\nSELECT taxpayer_id, taxpayer_name, period_year, period_month,\n       item_type, time_range, taxpayer_type, revision_no,\n       sales_taxable_rate, sales_goods, sales_services, sales_adjustment_check, sales_simple_method, sales_simple_adjust_check, sales_export_credit_refund, sales_tax_free, sales_tax_free_goods, sales_tax_free_services, output_tax, input_tax, last_period_credit, transfer_out, export_refund, tax_check_supplement, deductible_total, actual_deduct, tax_payable, end_credit, simple_tax, simple_tax_check_supplement, tax_reduction, total_tax_payable, unpaid_begin, export_receipt_tax, paid_current, prepaid_installment, prepaid_export_receipt, paid_last_period, paid_arrears, unpaid_end, arrears, supplement_refund, immediate_refund, unpaid_check_begin, paid_check_current, unpaid_check_end, city_maintenance_tax, education_surcharge, local_education_surcharge\nFROM latest\nWHERE rn = 1\nORDER BY period_year, period_month\nLIMIT 1000;\n\n-- [eit]\nWITH latest AS (\n  SELECT taxpayer_id, taxpayer_name, period_year, revision_no,\n         revenue, operating_profit, total_profit, taxable_income, tax_due, actual_tax_payable,\n         ROW_NUMBER() OVER (\n           PARTITION BY taxpayer_id, period_year\n           ORDER BY revision_no DESC\n         ) AS rn\n  FROM vw_eit_annual_main\n  WHERE taxpayer_id = '91310115MA2KZZZZZZ'\n    AND period_year BETWEEN 2024 AND 2025\n)\nSELECT \n  taxpayer_id,\n  taxpayer_name,\n  period_year,\n  revision_no,\n  revenue,\n  operating_profit,\n  total_profit,\n  taxable_income,\n  tax_due,\n  actual_tax_payable,\n  CASE WHEN revenue != 0 THEN ROUND(operating_profit * 100.0 / revenue, 2) ELSE NULL END AS operating_profit_margin,\n  CASE WHEN revenue != 0 THEN ROUND(tax_due * 100.0 / revenue, 2) ELSE NULL END AS eit_tax_burden_rate\nFROM latest \nWHERE rn = 1\nORDER BY period_year\nLIMIT 1000;",
