          "sql": "WITH latest AS (\n  SELECT taxpayer_id, taxpayer_name, period_year, revision_no,\n         revenue, operating_profit, taxable_income, actual_tax_payable\n  FROM vw_eit_annual_main\n  WHERE taxpayer_id = '91310115MA2KZZZZZZ'\n    AND period_year BETWEEN 2024 AND 2025\n),\nfiltered AS (\n  SELECT taxpayer_id, taxpayer_name, period_year,\n         revenue,\n         operating_profit,\n         taxable_income,\n         actual_tax_payable,\n         CASE WHEN revenue > 0 THEN ROUND(operating_profit * 100.0 / revenue, 2) ELSE NULL END AS operating_profit_margin,\n         CASE WHEN revenue > 0 THEN ROUND(actual_tax_payable * 100.0 / revenue, 2) ELSE NULL END AS eit_tax_burden_rate\n  FROM latest\n  WHERE revision_no = (SELECT MAX(revision_no) FROM latest AS sub WHERE sub.taxpayer_id = latest.taxpayer_id AND sub.period_year = latest.period_year)\n)\nSELECT taxpayer_id, taxpayer_name, period_year,\n       revenue, operating_profit, taxable_income, actual_tax_payable,\n       operating_profit_margin, eit_tax_burden_rate,\n       0 AS sort_key\nFROM filtered\nUNION ALL\nSELECT taxpayer_id, taxpayer_name, '合计' AS period_year,\n       SUM(revenue) AS revenue,\n       SUM(operating_profit) AS operating_profit,\n       SUM(taxable_income) AS taxable_income,\n       SUM(actual_tax_payable) AS actual_tax_payable,\n       CASE WHEN SUM(revenue) > 0 THEN ROUND(SUM(operating_profit) * 100.0 / SUM(revenue), 2) ELSE NULL END AS operating_profit_margin,\n       CASE WHEN SUM(revenue) > 0 THEN ROUND(SUM(actual_tax_payable) * 100.0 / SUM(revenue), 2) ELSE NULL END AS eit_tax_burden_rate,\n       1 AS sort_key\nFROM filtered\nGROUP BY taxpayer_id, taxpayer_name\nORDER BY sort_key, period_year\nLIMIT 1000;"
