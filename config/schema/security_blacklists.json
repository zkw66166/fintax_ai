{
  "_comment": "SQL安全黑名单",
  "denied_keywords": [
    "INSERT", "UPDATE", "DELETE", "MERGE", "REPLACE",
    "CREATE", "ALTER", "DROP", "TRUNCATE",
    "GRANT", "REVOKE", "PRAGMA", "ATTACH", "DETACH",
    "VACUUM", "LOAD_EXTENSION"
